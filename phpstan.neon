includes:
    - ./vendor/nunomaduro/larastan/extension.neon

parameters:

    paths:
        - app

    # The level 9 is the highest level
    level: 5

    ignoreErrors:
        - '#PHPDoc tag @var#'

    excludePaths:
        - ./.git
        - ./vendor/*
        - ./app/Services/Gmo/*
        - ./node_modules/*
        - ./app/Services/CognitoTokenApiGuard.php

    checkMissingIterableValueType: false
    reportUnmatchedIgnoredErrors: false
